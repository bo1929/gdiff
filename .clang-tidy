---
# Focused checks: bugs > performance > style noise
# Only checks whose auto-fix is safe are enabled here.
# Checks with broken auto-fix are excluded (see comments).
Checks: >
  bugprone-*,
  performance-*,
  portability-*,
  readability-convert-member-functions-to-static,
  readability-make-member-function-const,
  readability-math-missing-parentheses,
  modernize-use-nullptr,
  modernize-use-equals-default,
  modernize-use-equals-delete,
  modernize-use-override,
  -bugprone-forward-declaration-namespace,
  -bugprone-easily-swappable-parameters,
  -bugprone-reserved-identifier,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-macro-usage,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-cstyle-cast,
  -cppcoreguidelines-pro-type-const-cast,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -cppcoreguidelines-avoid-const-or-ref-data-members,
  -cppcoreguidelines-missing-std-forward,
  -cppcoreguidelines-special-member-functions,
  -cppcoreguidelines-narrowing-conversions,
  -modernize-use-auto,
  -modernize-use-nodiscard,
  -modernize-macro-to-enum,
  -modernize-avoid-c-style-cast,
  -modernize-use-trailing-return-type,
  -modernize-pass-by-value,
  -readability-magic-numbers,
  -readability-named-parameter,
  -readability-identifier-length,
  -readability-braces-around-statements,
  -readability-implicit-bool-conversion,
  -readability-use-concise-preprocessor-directives,
  -readability-uppercase-literal-suffix,
  -readability-use-std-min-max,
  -readability-isolate-declaration,
  -readability-const-return-type,
  -performance-enum-size,
  -performance-avoid-endl,
  -performance-move-const-arg,
  -performance-unnecessary-value-param,
  -portability-reserved-identifier

WarningsAsErrors: ''
HeaderFilterRegex: '(src/.*|\.hpp$)'
ExcludeHeaderFilterRegex: '(vendor/|CLI11|kseq|MurmurHash3)'
FormatStyle: file
CheckOptions:
  - key:   modernize-use-nullptr.NullMacros
    value: 'NULL'
...
